{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true
	},
	"include": ["src/**/*"],
	"exclude": [
		"src/convex/auth.ts",
		"src/convex/http.ts",
		"src/convex/projects.ts",
		"src/convex/schema.ts"
	]
}
